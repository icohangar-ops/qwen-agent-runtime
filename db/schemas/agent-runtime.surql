-- ============================================================
-- Senso Agent Runtime - Session & Audit Logging Schema
-- SurrealDB Multi-Model (Relational + Graph + Time-Series)
-- ============================================================
-- Tracks all agent sessions, commands, approvals, and outputs
-- across the 3-node cluster (laptop-primary, laptop-failover, mac-server)
-- ============================================================

USE NS senso;
USE DB agent_runtime;

-- ============================================================
-- TABLES
-- ============================================================

-- Agent Node: registered nodes in the cluster
DEFINE TABLE agent_node SCHEMAFULL
    PERMISSIONS
        FOR select FULL,
        FOR create WHERE $auth.level >= 'admin',
        FOR update WHERE $auth.level >= 'admin',
        FOR delete WHERE $auth.level >= 'admin';

DEFINE FIELD agent_id ON TABLE agent_node TYPE string ASSERT string::len($value) > 0;
DEFINE FIELD hostname ON TABLE agent_node TYPE string;
DEFINE FIELD platform ON TABLE agent_node TYPE string; -- windows, macos, linux
DEFINE FIELD os_version ON TABLE agent_node TYPE string;
DEFINE FIELD shell ON TABLE agent_node TYPE string; -- powershell, bash, zsh
DEFINE FIELD python_version ON TABLE agent_node TYPE string;
DEFINE FIELD llm_provider ON TABLE agent_node TYPE string; -- groq, deepseek
DEFINE FIELD llm_model ON TABLE agent_node TYPE string; -- llama-3.3-70b, deepseek-chat
DEFINE FIELD ip_address ON TABLE agent_node TYPE option<string>;
DEFINE FIELD status ON TABLE agent_node TYPE string DEFAULT 'active'; -- active, inactive, offline
DEFINE FIELD first_seen ON TABLE agent_node TYPE datetime DEFAULT time::now();
DEFINE FIELD last_heartbeat ON TABLE agent_node TYPE datetime DEFAULT time::now();

DEFINE INDEX idx_node_agent_id ON TABLE agent_node FIELDS agent_id UNIQUE;
DEFINE INDEX idx_node_status ON TABLE agent_node FIELDS status;

-- Session: each time an agent starts (python -m agent)
DEFINE TABLE session SCHEMAFULL
    PERMISSIONS
        FOR select WHERE owner = $auth.agent OR $auth.level >= 'admin',
        FOR create WHERE $auth.level >= 'user',
        FOR update WHERE $auth.level >= 'admin',
        FOR delete WHERE $auth.level >= 'admin';

DEFINE FIELD session_id ON TABLE session TYPE string;
DEFINE FIELD agent ON TABLE session TYPE record<agent_node>;
DEFINE FIELD started_at ON TABLE session TYPE datetime DEFAULT time::now();
DEFINE FIELD ended_at ON TABLE session TYPE option<datetime>;
DEFINE FIELD command_count ON TABLE session TYPE int DEFAULT 0;
DEFINE FIELD approved_count ON TABLE session TYPE int DEFAULT 0;
DEFINE FIELD rejected_count ON TABLE session TYPE int DEFAULT 0;
DEFINE FIELD blocked_count ON TABLE session TYPE int DEFAULT 0;
DEFINE FIELD error_count ON TABLE session TYPE int DEFAULT 0;

DEFINE INDEX idx_session_id ON TABLE session FIELDS session_id UNIQUE;
DEFINE INDEX idx_session_agent ON TABLE session FIELDS agent;
DEFINE INDEX idx_session_started ON TABLE session FIELDS started_at;

-- Command: every command generated by the LLM
DEFINE TABLE command SCHEMAFULL
    PERMISSIONS
        FOR select WHERE session.agent = $auth.agent OR $auth.level >= 'admin',
        FOR create WHERE $auth.level >= 'user',
        FOR update WHERE $auth.level >= 'admin',
        FOR delete WHERE $auth.level >= 'admin';

DEFINE FIELD session ON TABLE command TYPE record<session>;
DEFINE FIELD sequence ON TABLE command TYPE int;
DEFINE FIELD user_prompt ON TABLE command TYPE string; -- what the user typed
DEFINE FIELD generated_command ON TABLE command TYPE string; -- LLM output
DEFINE FIELD approved_command ON TABLE command TYPE option<string>; -- actual command run (may be edited)
DEFINE FIELD decision ON TABLE command TYPE string; -- approved, rejected, edited, blocked
DEFINE FIELD blocked_by ON TABLE command TYPE option<string>; -- guardrail rule that blocked it
DEFINE FIELD reason ON TABLE command TYPE option<string>; -- user or system reason
DEFINE FIELD executed_at ON TABLE command TYPE option<datetime>;
DEFINE FIELD duration_ms ON TABLE command TYPE option<int>; -- execution time
DEFINE FIELD exit_code ON TABLE command TYPE option<int>;
DEFINE FIELD output_length ON TABLE command TYPE option<int>;
DEFINE FIELD output_truncated ON TABLE command TYPE bool DEFAULT false;
DEFINE FIELD created_at ON TABLE command TYPE datetime DEFAULT time::now();

DEFINE INDEX idx_cmd_session ON TABLE command FIELDS session;
DEFINE INDEX idx_cmd_decision ON TABLE command FIELDS decision;
DEFINE INDEX idx_cmd_created ON TABLE command FIELDS created_at;
DEFINE INDEX ft_cmd_prompt ON TABLE command FIELDS user_prompt, generated_command SEARCH ANALYZER bm25 TOKENIZERS blank,class;

-- Audit Log: immutable event log for compliance and debugging
DEFINE TABLE audit_log SCHEMAFULL
    PERMISSIONS
        FOR select WHERE $auth.level >= 'admin',
        FOR create WHERE $auth.level >= 'user';

DEFINE FIELD timestamp ON TABLE audit_log TYPE datetime DEFAULT time::now();
DEFINE FIELD agent_id ON TABLE audit_log TYPE string;
DEFINE FIELD session_id ON TABLE audit_log TYPE option<string>;
DEFINE FIELD action ON TABLE audit_log TYPE string;
    -- session_start, session_end, command_generated, command_approved,
    -- command_rejected, command_blocked, command_executed, command_error,
    -- guardrail_triggered, config_changed, agent_heartbeat
DEFINE FIELD level ON TABLE audit_log TYPE string DEFAULT 'info'; -- info, warn, error, critical
DEFINE FIELD detail ON TABLE audit_log TYPE option<object>;
DEFINE FIELD resource ON TABLE audit_log TYPE option<record>;

DEFINE INDEX idx_audit_agent ON TABLE audit_log FIELDS agent_id;
DEFINE INDEX idx_audit_action ON TABLE audit_log FIELDS action;
DEFINE INDEX idx_audit_level ON TABLE audit_log FIELDS level;
DEFINE INDEX idx_audit_timestamp ON TABLE audit_log FIELDS timestamp;

-- Guardrail Rule: configurable deny-list and patterns
DEFINE TABLE guardrail_rule SCHEMAFULL
    PERMISSIONS
        FOR select FULL,
        FOR create WHERE $auth.level >= 'admin',
        FOR update WHERE $auth.level >= 'admin',
        FOR delete WHERE $auth.level >= 'admin';

DEFINE FIELD name ON TABLE guardrail_rule TYPE string ASSERT string::len($value) > 0;
DEFINE FIELD pattern ON TABLE guardrail_rule TYPE string; -- regex pattern
DEFINE FIELD pattern_type ON TABLE guardrail_rule TYPE string; -- regex, exact, substring
DEFINE FIELD severity ON TABLE guardrail_rule TYPE string DEFAULT 'block'; -- block, warn, log
DEFINE FIELD description ON TABLE guardrail_rule TYPE string;
DEFINE FIELD enabled ON TABLE guardrail_rule TYPE bool DEFAULT true;
DEFINE FIELD hit_count ON TABLE guardrail_rule TYPE int DEFAULT 0;
DEFINE FIELD last_hit ON TABLE guardrail_rule TYPE option<datetime>;
DEFINE FIELD created_at ON TABLE guardrail_rule TYPE datetime DEFAULT time::now();

DEFINE INDEX idx_guard_name ON TABLE guardrail_rule FIELDS name UNIQUE;
DEFINE INDEX idx_guard_enabled ON TABLE guardrail_rule FIELDS enabled;

-- ============================================================
-- GRAPH EDGES
-- ============================================================

-- Command triggered a guardrail rule
DEFINE TABLE triggered_rule SCHEMAFULL TYPE RELATION IN command OUT guardrail_rule;

-- ============================================================
-- EVENTS (triggers)
-- ============================================================

-- Update session counters when a command is created
DEFINE EVENT update_session_counts ON TABLE command WHEN $event = 'CREATE' THEN (
    IF $after.decision = 'approved' THEN (
        UPDATE $after.session SET
            command_count += 1,
            approved_count += 1
    ) ELSE IF $after.decision = 'rejected' THEN (
        UPDATE $after.session SET
            command_count += 1,
            rejected_count += 1
    ) ELSE IF $after.decision = 'blocked' THEN (
        UPDATE $after.session SET
            command_count += 1,
            blocked_count += 1
    )
);

-- Increment guardrail hit count when triggered
DEFINE EVENT update_guardrail_hits ON TABLE triggered_rule WHEN $event = 'CREATE' THEN (
    UPDATE $after.out SET
        hit_count += 1,
        last_hit = time::now()
);

-- ============================================================
-- SAMPLE DATA
-- ============================================================

-- Agent nodes
CREATE agent_node SET
    agent_id = 'laptop-primary',
    hostname = 'SHYAM-LAPTOP1',
    platform = 'windows',
    os_version = 'Windows 11',
    shell = 'powershell',
    python_version = '3.11',
    llm_provider = 'groq',
    llm_model = 'llama-3.3-70b-versatile',
    status = 'active';

CREATE agent_node SET
    agent_id = 'laptop-failover',
    hostname = 'SHYAM-LAPTOP2',
    platform = 'windows',
    os_version = 'Windows 11',
    shell = 'powershell',
    python_version = '3.11',
    llm_provider = 'groq',
    llm_model = 'llama-3.3-70b-versatile',
    status = 'active';

CREATE agent_node SET
    agent_id = 'mac-server',
    hostname = 'senso-mac',
    platform = 'linux',
    os_version = 'Debian 13',
    shell = 'bash',
    python_version = '3.13',
    llm_provider = 'deepseek',
    llm_model = 'deepseek-chat',
    status = 'active';

-- Guardrail rules
CREATE guardrail_rule SET
    name = 'rm-rf-root',
    pattern = 'rm\\s+-rf\\s+/',
    pattern_type = 'regex',
    severity = 'block',
    description = 'Prevents recursive force deletion of root filesystem';

CREATE guardrail_rule SET
    name = 'disk-format',
    pattern = 'format',
    pattern_type = 'substring',
    severity = 'block',
    description = 'Blocks disk format commands';

CREATE guardrail_rule SET
    name = 'registry-destructive',
    pattern = 'Remove-Item.*HKLM:\\\\.*-Recurse',
    pattern_type = 'regex',
    severity = 'block',
    description = 'Prevents recursive deletion of HKLM registry keys';

CREATE guardrail_rule SET
    name = 'shutdown-reboot',
    pattern = 'shutdown|restart|reboot',
    pattern_type = 'substring',
    severity = 'warn',
    description = 'Warns about system shutdown/restart commands';

